PORT=3000
TELEGRAM_BOT_TOKEN=123456789:replace_with_token_from_botfather
TELEGRAM_CHAT_ID=123456789
SHARED_SECRET=replace_with_long_random_secret

# Recommended free mode: Gmail IMAP polling. Outlook should server-forward TODO
# letters to Gmail, and this service polls Gmail on Render.
GMAIL_POLLING_ENABLED=false
GMAIL_POLL_INTERVAL_SECONDS=120
GMAIL_STATE_FILE=.data/gmail-state.json
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993
GMAIL_IMAP_SECURE=true
GMAIL_IMAP_USER=your-gmail@gmail.com
GMAIL_IMAP_PASSWORD=replace_with_gmail_app_password
GMAIL_IMAP_MAILBOX=INBOX
GMAIL_IMAP_MARK_SEEN=true

# Optional legacy mode: Microsoft Graph polling. This requires Entra admin approval.
GRAPH_POLLING_ENABLED=false
GRAPH_POLL_INTERVAL_SECONDS=120
GRAPH_LOOKBACK_MINUTES=5
GRAPH_STATE_FILE=.data/graph-state.json
TODO_SUBJECT_KEYWORD=TODO

# Microsoft Graph delegated OAuth settings.
MS_TENANT_ID=45abff8b-eeda-41e5-99d4-2e7def6de1fe
MS_CLIENT_ID=replace_with_azure_app_client_id
MS_CLIENT_SECRET=replace_if_your_app_uses_a_client_secret
MS_REDIRECT_URI=http://localhost:3001/callback
MS_REFRESH_TOKEN=replace_with_refresh_token_from_npm_run_auth_microsoft
MS_MAILBOX_USER=dmitry.vaisman@metropolinet.co.il
